<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CATETIC SHOWDOWN</title>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; background: #000; overflow: hidden; display: flex; justify-content: center; align-items: center; }
        #gameCanvas { aspect-ratio: 9 / 16; height: 100vh; max-width: 100%; background: #0a0a0c; display: block; }
    </style>
</head>
<body>

    <canvas id="gameCanvas" width="1080" height="1920"></canvas>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        let currentScreen = "MENU";

        canvas.addEventListener('touchstart', (e) => {
            e.preventDefault();
            const rect = canvas.getBoundingClientRect();
            const touchX = ((e.touches[0].clientX - rect.left) / rect.width) * 1080;
            const touchY = ((e.touches[0].clientY - rect.top) / rect.height) * 1920;

            if (currentScreen === "MENU") {
                // 1. "CATETIC" Logo Invisible Hitbox (Top Core)
                if (touchX > 150 && touchX < 930 && touchY > 100 && touchY < 450) {
                    console.log("💎 [DEV CODE] Secret Catetic Signature Accessed.");
                }
                // 2. "START スタート" Invisible Hitbox (Lower Base Button)
                if (touchX > 250 && touchX < 830 && touchY > 1500 && touchY < 1850) {
                    currentScreen = "COMBAT";
                    console.log("🎮 Combat Initialized.");
                }
            } else if (currentScreen === "COMBAT") {
                if (touchY > 960) {
                    console.log("💥 DELETE Combo Input Sent.");
                }
            }
        });

        function drawLoop() {
            ctx.clearRect(0, 0, 1080, 1920);
            if (currentScreen === "MENU") {
                ctx.fillStyle = "#111";
                ctx.fillRect(0, 0, 1080, 1920);
                ctx.fillStyle = "#a1a1aa";
                ctx.font = "bold 40px monospace";
                ctx.fillText("[ MENU GRAPHICS PLACEHOLDER ]", 220, 960);
            } else {
                ctx.fillStyle = "#050507";
                ctx.fillRect(0, 0, 1080, 1920);
                ctx.fillStyle = "#38bdf8";
                ctx.font = "bold 45px monospace";
                ctx.fillText("=== COMBAT ARENA ACTIVE ===", 220, 250);
            }
            requestAnimationFrame(drawLoop);
        }
        drawLoop();
    </script>
</body>
</html>
